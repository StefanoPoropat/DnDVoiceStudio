<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Assets\NPCPortraits\default.png" />
    <None Remove="Assets\PreviewVoices\voice-message.wav" />
    <None Remove="Assets\Sounds\Music\Final-Nice to meet you.wav" />
    <None Remove="Config\presets.json" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\NPCPortraits\default.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Assets\Sounds\Music\Final-Nice to meet you.wav">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Config\_deleted\presets.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
    <PackageReference Include="NAudio" Version="2.3.0" />
    <PackageReference Include="SoundTouch.Net" Version="2.3.2" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Assets\Sounds\Monsters\" />
    <Folder Include="Assets\Sounds\Magic\" />
    <Folder Include="Assets\Sounds\Combat\" />
    <Folder Include="Assets\Sounds\Ambience\" />
    <Folder Include="Assets\Sounds\NPC\" />
    <Folder Include="NewFolder\" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\PreviewVoices\voice-message.wav">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <None Update="Data\npcs.json">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
